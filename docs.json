{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Space64 Docs",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["introduction", "quickstart"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": ["api-reference/introduction"]
          },
          {
            "group": "Templates",
            "pages": [
              "api-reference/list-templates",
              "api-reference/get-template",
              "api-reference/run-template"
            ]
          },
          {
            "group": "Workflows",
            "pages": [
              "api-reference/run-workflow",
              "api-reference/get-run"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "App",
          "href": "https://space64.ai",
          "icon": "rocket"
        },
        {
          "anchor": "Twitter",
          "href": "https://x.com/space64ai",
          "icon": "x-twitter"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "App",
        "href": "https://space64.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://space64.ai"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/space64ai"
    }
  }
}
